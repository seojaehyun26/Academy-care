rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles (academy admins + parents).
    // Parents must not be able to grant themselves approval, and only the
    // academy a parent is linked to (academyId) may approve/reject them.
    match /users/{userId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && (
          request.resource.data.role == 'academy'
          || (
            request.resource.data.role == 'parent'
            && request.resource.data.approved == false
            && exists(/databases/$(database)/documents/users/$(request.resource.data.academyId))
            && get(/databases/$(database)/documents/users/$(request.resource.data.academyId)).data.role == 'academy'
          )
        );

      allow update: if request.auth != null && (
        (
          request.auth.uid == userId
          && request.resource.data.get('approved', null) == resource.data.get('approved', null)
          && request.resource.data.get('academyId', null) == resource.data.get('academyId', null)
        )
        || (
          resource.data.get('role', null) == 'parent'
          && resource.data.get('academyId', null) == request.auth.uid
        )
      );

      allow delete: if false;
    }

    // Public-readable lookup of an academy's join code -> academyId.
    // No PII lives here, so an unauthenticated `get` (signup-time validation)
    // is safe. `list` stays closed so codes can't be enumerated.
    //
    // A code can only be created pointing at the caller's own uid — it does
    // NOT verify the caller is actually an academy here, because that would
    // require reading /users/{academyId} in the same security check as the
    // /users/{academyId} document write that creates the academy account,
    // and write ordering between the two isn't guaranteed to be visible to
    // rules evaluation. The real enforcement lives in /users create below:
    // a parent signup is only accepted if academyId resolves to a doc whose
    // role is actually 'academy', so a code pointing at a non-academy uid
    // is harmless dead weight, not a privilege escalation.
    match /academyCodes/{code} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null
        && request.resource.data.academyId == request.auth.uid;
      allow update, delete: if false;
    }

    match /students/{studentId} {
      allow read, write: if request.auth != null;
    }

    match /academySettings/{academyId} {
      allow read, write: if request.auth != null;
    }

    match /announcements/{announcementId} {
      allow read, write: if request.auth != null;
    }

    match /consultations/{consultationId} {
      allow read, write: if request.auth != null;
    }

    match /homework/{homeworkId} {
      allow read, write: if request.auth != null;
    }

    match /attendance_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    match /chats/{roomId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Community board posts, scoped per-academy. Anyone signed in can read,
    // comment, and like (update), but only the original author can delete
    // their own post or comment — no academy-side moderation delete.
    match /communityPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid;
        allow update: if false;
        allow delete: if request.auth != null
          && resource.data.authorId == request.auth.uid;
      }
    }
  }
}
